{
  "name": "payday-eoselia-tg-bot",
  "version": "1.0.0",
  "description": "A lightweight Telegram bot designed to manage and track єОселя mortgage payments",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --tsconfig tsconfig.json src/index.ts",
    "start": "cross-env NODE_ENV=development node dist/index.js",
    "build": "tsc && tsc-alias",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "npm run tool-prettier -- --list-different \"**/*.{js,ts}\"",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "npm run tool-prettier -- --write \"**/*.{js,ts}\"",
    "tool-prettier": "prettier --ignore-path .gitignore",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grammyjs/emoji": "^1.2.0",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/storage-free": "^2.5.1",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "date-fns": "^4.1.0",
    "grammy": "^1.39.2",
    "grammy-guard": "^0.5.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "envalid": "^8.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pm2": "^6.0.14",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}
